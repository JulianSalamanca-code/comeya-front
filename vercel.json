{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/comeya/browser",
  "installCommand": "npm install",
  "framework": "angular",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/ngsw.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
